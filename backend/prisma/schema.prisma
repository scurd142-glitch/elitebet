// EliteBet — PostgreSQL schema
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum AccountStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
  BANNED
}

enum UserVerificationTier {
  NONE
  BASIC
  PREMIUM
}

enum PaymentProvider {
  STRIPE
  PAYSTACK
  PAYPAL
  MANUAL
}

enum PaymentType {
  ACCOUNT_ACTIVATION
  DEPOSIT
  ADVERTISING
  OTHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  DISPUTED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletTransactionReason {
  DEPOSIT
  REFERRAL_BONUS
  WITHDRAWAL
  ACTIVATION_FEE
  PLATFORM_FEE
  ADJUSTMENT
  BONUS
  BET
  WIN
  TRANSFER
  OTHER
}

enum WithdrawalMethod {
  PAYSTACK
  PAYPAL
  BANK_TRANSFER
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  FAILED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationType {
  SYSTEM
  PAYMENT
  WITHDRAWAL
  REFERRAL
  SECURITY
  BET
  PROMOTION
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  LOGIN
}

enum AdminLogAction {
  USER_BAN
  USER_UNBAN
  USER_ACTIVATE
  USER_DEACTIVATE
  WITHDRAWAL_APPROVE
  WITHDRAWAL_REJECT
  PAYMENT_VERIFY
  CONTENT_MODERATION
  SYSTEM_CONFIG
  OTHER
}

// -----------------------------------------------------------------------------
// Auth & users
// -----------------------------------------------------------------------------

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserRole[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  fullName      String
  phone         String?
  country       String?
  accountStatus AccountStatus @default(INACTIVE)
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  verificationTier UserVerificationTier @default(NONE)
  twoFactorEnabled Boolean @default(false)
  isVerified    Boolean   @default(false)
  promoCode     String?

  referralCode String @unique
  referredById String?
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[] @relation("UserReferrals")

  roles UserRole[]

  wallet            Wallet?
  payments          Payment[]
  walletTransactions WalletTransaction[] @relation("WalletTxActor")

  referralsMade Referral[] @relation("ReferrerUser")
  referredAs    Referral[] @relation("ReferredUser")

  withdrawals Withdrawal[]

  notifications Notification[]

  adminLogsTarget AdminLog[] @relation("AdminLogTargetUser")
  adminLogsActor  AdminLog[] @relation("AdminLogActor")

  supportTickets SupportTicket[]

  refreshTokens RefreshToken[]
  otpCodes      OtpVerification[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([email])
  @@index([username])
  @@index([accountStatus])
  @@index([referredById])
  @@index([createdAt])
  @@index([deletedAt])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  userAgent  String?
  ipAddress  String?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model OtpVerification {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email      String?
  phone      String?
  purpose    OtpPurpose
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
  @@index([phone, purpose])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Payments & wallet
// -----------------------------------------------------------------------------

model Payment {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal         @db.Decimal(18, 2)
  currency      String          @default("KES")
  provider      PaymentProvider
  type          PaymentType
  status        PaymentStatus   @default(PENDING)
  externalRef   String?
  idempotencyKey String?        @unique
  metadata      Json?
  completedAt   DateTime?
  failedReason  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  walletTransactions WalletTransaction[]

  @@index([userId, status])
  @@index([provider, externalRef])
  @@index([createdAt])
}

model Wallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Decimal  @default(0) @db.Decimal(18, 2)
  casinoBalance  Decimal  @default(0) @db.Decimal(18, 2)
  bonusBalance   Decimal  @default(0) @db.Decimal(18, 2)
  pendingBalance Decimal  @default(0) @db.Decimal(18, 2)
  currency       String   @default("KES")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions WalletTransaction[]
}

model WalletTransaction {
  id            String                  @id @default(cuid())
  walletId      String
  wallet        Wallet                  @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          WalletTransactionType
  reason        WalletTransactionReason
  amount        Decimal                 @db.Decimal(18, 2)
  balanceAfter  Decimal                 @db.Decimal(18, 2)
  paymentId     String?
  payment       Payment?                @relation(fields: [paymentId], references: [id])
  referenceType String?
  referenceId   String?
  description   String?
  metadata      Json?
  actorUserId   String?
  actorUser     User?                   @relation("WalletTxActor", fields: [actorUserId], references: [id])
  createdAt     DateTime                @default(now())

  @@index([walletId, createdAt])
  @@index([referenceType, referenceId])
}

model Withdrawal {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Decimal           @db.Decimal(18, 2)
  currency      String            @default("KES")
  method        WithdrawalMethod
  status        WithdrawalStatus  @default(PENDING)
  destination   String?
  adminNotes    String?
  processedById String?
  processedAt   DateTime?
  failureReason String?
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

// -----------------------------------------------------------------------------
// Referrals
// -----------------------------------------------------------------------------

model Referral {
  id               String   @id @default(cuid())
  referrerId       String
  referrer         User     @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId   String   @unique
  referredUser     User     @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  level            Int      @default(1)
  commissionEarned Decimal @default(0) @db.Decimal(18, 2)
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([referrerId])
}

// -----------------------------------------------------------------------------
// Notifications
// -----------------------------------------------------------------------------

model Notification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String               @db.Text
  type      NotificationType
  channel   NotificationChannel  @default(IN_APP)
  data      Json?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// Admin & audit
// -----------------------------------------------------------------------------

model AdminLog {
  id          String         @id @default(cuid())
  actorId     String
  actor       User           @relation("AdminLogActor", fields: [actorId], references: [id], onDelete: Cascade)
  action      AdminLogAction
  targetType  String?
  targetId    String?
  targetUserId String?
  targetUser  User?          @relation("AdminLogTargetUser", fields: [targetUserId], references: [id])
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

// -----------------------------------------------------------------------------
// Support & content
// -----------------------------------------------------------------------------

model SupportTicket {
  id        String                @id @default(cuid())
  userId    String?
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  subject   String
  message   String                @db.Text
  status    SupportTicketStatus   @default(OPEN)
  priority  SupportTicketPriority @default(NORMAL)
  metadata  Json?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([status, priority])
  @@index([userId])
}

model Faq {
  id         String   @id @default(cuid())
  question   String
  answer     String   @db.Text
  category   String?
  sortOrder  Int      @default(0)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published, category])
}
